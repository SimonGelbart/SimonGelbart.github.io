---
import SiteLayout from '../../layouts/SiteLayout.astro';
import LearningCard from '../../components/LearningCard.astro';
import { learningPaths } from '../../data/learningPaths';
const featuredPath = learningPaths[0];
---
<SiteLayout title="Learning paths — Simon Gelbart" current="learning">
  <section class="page-heading narrow">
    <p class="eyebrow">Learning paths</p>
    <h1>Learning paths</h1>
    <p class="lede">Learning material is another output of the lab: not a course marketplace, not a blog archive, but a place to shape backend design topics into practical paths.</p>
  </section>

  <section class="section split">
    <div>
      <p class="eyebrow">Teaching method</p>
      <h2>Small decisions, visible trade-offs.</h2>
    </div>
    <div class="panel prose-panel"><p>I try to teach through small decisions: show a model, expose the trade-off, ask what can go wrong, then improve it.</p></div>
  </section>

  <section class="section">
    <LearningCard path={featuredPath} featured showStatusText />
  </section>

  <section class="section section-compact">
    <div class="note">Future paths will appear when a topic has enough examples, trade-offs, and structure to become useful learning material.</div>
  </section>
</SiteLayout>
