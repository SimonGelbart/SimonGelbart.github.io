---
import SiteLayout from '../../layouts/SiteLayout.astro';
import ProjectRow from '../../components/ProjectRow.astro';
import { projects } from '../../data/projects';
---
<SiteLayout title="Projects — Simon Gelbart" current="projects">
  <section class="page-heading narrow">
    <p class="eyebrow">Projects</p>
    <h1>Projects</h1>
    <p class="lede">A richer index of the public experiments behind the lab. Each project is active, evolving, and documented enough to inspect.</p>
  </section>

  <section class="project-list" aria-label="Public experiments">
    {projects.map((project) => <ProjectRow project={project} />)}
  </section>

  <section class="section section-compact">
    <div class="note">Some applied experiments are still private or too early to publish. They may become public once there is enough code, documentation, and context to inspect.</div>
  </section>
</SiteLayout>
